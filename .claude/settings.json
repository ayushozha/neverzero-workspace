{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "node scripts/nz-hook.mjs session-start" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "node scripts/nz-hook.mjs user-prompt" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|Bash|TodoWrite|Read|Glob|Grep",
        "hooks": [
          { "type": "command", "command": "node scripts/nz-hook.mjs post-tool-use" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "node scripts/nz-hook.mjs stop" }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          { "type": "command", "command": "node scripts/nz-hook.mjs session-end" }
        ]
      }
    ]
  }
}
